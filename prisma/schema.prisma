// ========================================================
// PATH: prisma/schema.prisma
// D-EscapeRoom — Next.js 15 + Prisma ORM
// ========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================================
// ENUMS
// ========================================================

enum Role {
  ADMIN
  PARTNER
}

enum SlotStatus {
  DRAFT
  PUBLISHED
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  REMAINING
  REFUND
}

enum PaymentProvider {
  MOLLIE
  OFFLINE
  MANUAL
}

enum Province {
  DRENTHE
  FLEVOLAND
  FRIESLAND
  GELDERLAND
  GRONINGEN
  LIMBURG
  NOORD_BRABANT
  NOORD_HOLLAND
  OVERIJSSEL
  UTRECHT
  ZEELAND
  ZUID_HOLLAND
}

enum DiscountType {
  PERCENT
  FIXED
}

// ========================================================
// MODELS
// ========================================================

model AppUser {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        Role

  partner     Partner? @relation(fields: [partnerId], references: [id])
  partnerId   String?

  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role])
  @@index([partnerId])
}

model Partner {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  email           String?
  province        Province @default(UTRECHT)
  phone           String?
  isActive        Boolean  @default(true)

  price1PaxCents  Int      @default(4995)
  price2PlusCents Int      @default(3995)

  feePercent      Int

  heroImageUrl    String?
  addressLine1    String?
  addressLine2    String?
  postalCode      String?
  city            String?
  country         String?  @default("NL")
  timezone        String   @default("Europe/Amsterdam")
  googleMapsUrl   String?  @db.Text

  users           AppUser[]
  slots           Slot[]
  bookings        Booking[]
  reviews         Review[]

  giftCards       GiftCard[]      @relation("PartnerGiftCards")
  giftCardOrders  GiftCardOrder[] @relation("PartnerGiftCardOrders")
  discountCodes   DiscountCode[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Slot {
  id          String     @id @default(cuid())

  partner     Partner    @relation(fields: [partnerId], references: [id])
  partnerId   String

  startTime   DateTime
  endTime     DateTime
  status      SlotStatus @default(DRAFT)

  capacity    Int        @default(1)
  maxPlayers  Int        @default(3)

  publishedAt DateTime?
  bookedAt    DateTime?

  booking     Booking?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([partnerId, startTime])
  @@index([partnerId, startTime])
  @@index([partnerId, status, startTime])
  @@index([status])
  @@index([startTime])
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @db.Text
  name      String?
  phone     String?
  locale    String?

  bookings  Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Booking {
  id                   String        @id @default(cuid())

  partner              Partner       @relation(fields: [partnerId], references: [id])
  partnerId            String

  slot                 Slot          @relation(fields: [slotId], references: [id])
  slotId               String        @unique

  customer             Customer      @relation(fields: [customerId], references: [id])
  customerId           String

  status               BookingStatus @default(PENDING)
  emailsSentAt         DateTime?
  reviewRequestSentAt  DateTime?

  currency             String        @default("EUR")
  totalAmountCents     Int
  depositAmountCents   Int
  restAmountCents      Int

  playersCount         Int           @default(1)
  dogName              String?
  dogAllergies         String?
  dogFears             String?
  dogTrackingLevel     String?
  dogSocialWithPeople  Boolean?

  acceptedTerms        Boolean       @default(false)
  acceptedTermsAt      DateTime?
  acceptedTermsVersion String?

  giftCardId           String?
  giftCard             GiftCard?     @relation("BookingGiftCard", fields: [giftCardId], references: [id])
  giftCardAppliedCents Int?

  discountCodeId       String?
  discountCode         DiscountCode? @relation(fields: [discountCodeId], references: [id])
  discountAmountCents  Int           @default(0)

  confirmedAt          DateTime?
  cancelledAt          DateTime?
  depositPaidAt        DateTime?

  payments             Payment[]
  refunds              Refund[]
  redemptions          GiftCardRedemption[] @relation("BookingRedemptions")

  review               Review?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([partnerId])
  @@index([customerId])
  @@index([status])
  @@index([discountCodeId])
  @@index([cancelledAt])
  @@index([createdAt])
  @@index([reviewRequestSentAt])
}

model Payment {
  id                  String          @id @default(cuid())

  booking             Booking         @relation(fields: [bookingId], references: [id])
  bookingId           String

  provider            PaymentProvider
  type                PaymentType     @default(DEPOSIT)
  status              PaymentStatus   @default(CREATED)

  providerPaymentId   String?         @unique
  method              String?
  rawPayload          Json?

  currency            String          @default("EUR")
  amountCents         Int

  paidAt              DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  refunds             Refund[]
  giftCardRedemptions GiftCardRedemption[] @relation("PaymentRedemptions")

  @@index([bookingId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Refund {
  id               String          @id @default(cuid())

  booking          Booking         @relation(fields: [bookingId], references: [id])
  bookingId        String

  payment          Payment         @relation(fields: [paymentId], references: [id])
  paymentId        String

  amountCents      Int
  currency         String          @default("EUR")

  provider         PaymentProvider @default(MOLLIE)
  providerRefundId String?
  reason           String?

  createdAt        DateTime        @default(now())

  @@index([bookingId])
  @@index([paymentId])
}

model LoginCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ========================================================
// REVIEWS
// ========================================================

model Review {
  id            String   @id @default(cuid())

  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bookingId     String?  @unique

  partner       Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  partnerId     String?

  name          String
  dogName       String?
  rating        Int
  message       String   @db.Text

  consent       Boolean  @default(false)
  isPublished   Boolean  @default(false)

  googleAskedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partnerId])
  @@index([isPublished])
  @@index([createdAt])
}

// ========================================================
// GIFT CARDS
// ========================================================

model GiftCard {
  id                 String   @id @default(cuid())
  code               String   @unique
  currency           String   @default("EUR")
  initialAmountCents Int
  balanceCents       Int
  isActive           Boolean  @default(true)
  expiresAt          DateTime?

  partnerId          String?
  partner            Partner? @relation("PartnerGiftCards", fields: [partnerId], references: [id])

  bookings           Booking[]            @relation("BookingGiftCard")
  redemptions        GiftCardRedemption[] @relation("CardRedemptions")
  orders             GiftCardOrder[]      @relation("OrderGiftCard")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([partnerId])
  @@index([isActive, expiresAt])
}

model GiftCardRedemption {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  amountCents Int

  giftCardId  String
  giftCard    GiftCard @relation("CardRedemptions", fields: [giftCardId], references: [id])

  bookingId   String?
  booking     Booking? @relation("BookingRedemptions", fields: [bookingId], references: [id])

  paymentId   String?
  payment     Payment? @relation("PaymentRedemptions", fields: [paymentId], references: [id])

  @@index([giftCardId])
  @@index([bookingId])
  @@index([paymentId])
}

model GiftCardOrder {
  id                String    @id @default(cuid())

  status            String    @default("CREATED")

  purchaserEmail    String
  purchaserName     String?
  recipientEmail    String?
  recipientName     String?
  message           String?

  currency          String    @default("EUR")
  amountCents       Int

  partnerId         String?
  partner           Partner?  @relation("PartnerGiftCardOrders", fields: [partnerId], references: [id])

  provider          String    @default("MOLLIE")
  providerPaymentId String?   @unique
  checkoutUrl       String?
  paidAt            DateTime?

  giftCardId        String?
  giftCard          GiftCard? @relation("OrderGiftCard", fields: [giftCardId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([partnerId])
}

// ========================================================
// DISCOUNT CODES
// ========================================================

model DiscountCode {
  id              String       @id @default(cuid())
  code            String       @unique
  type            DiscountType
  percent         Int?
  amountCents     Int?
  validFrom       DateTime?
  validUntil      DateTime?
  maxRedemptions  Int?
  redeemedCount   Int          @default(0)
  active          Boolean      @default(true)

  partnerId       String
  partner         Partner      @relation(fields: [partnerId], references: [id])

  createdByUserId String?
  createdByRole   Role?

  bookings        Booking[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([partnerId])
  @@index([active, validFrom, validUntil])
}

// ========================================================
// CHAT
// ========================================================

model ChatSession {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  role      String
  locale    String

  messages  ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  from      String
  content   String

  @@index([sessionId])
  @@index([createdAt])
}

// ========================================================
// CONSENT LOGS
// ========================================================

model ConsentLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  version     String
  locale      String?
  preferences Json

  ipHash      String?
  userAgent   String?
  referer     String?
}